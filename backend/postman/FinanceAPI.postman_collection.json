{
  "info": {
    "_postman_id": "f0d1f3a2-6a49-4d0e-9cc7-3b0614bd8218",
    "name": "Finance API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "recordId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"123456\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Users (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Records",
      "item": [
        {
          "name": "Create Record (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json._id) {",
                  "  pm.collectionVariables.set('recordId', json._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "{{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 5000,\n  \"type\": \"income\",\n  \"category\": \"Salary\",\n  \"note\": \"Monthly salary\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/records",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "records"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Records",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/records?type=income&category=Salary",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "records"
              ],
              "query": [
                {
                  "key": "type",
                  "value": "income"
                },
                {
                  "key": "category",
                  "value": "Salary"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Record (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "{{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 5500,\n  \"note\": \"Updated salary amount\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/records/{{recordId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "records",
                "{{recordId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete Record (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/records/{{recordId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "records",
                "{{recordId}}"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Summary (Analyst/Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/dashboard/summary",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "dashboard",
                "summary"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Category (Analyst/Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/dashboard/category",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "dashboard",
                "category"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
